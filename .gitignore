# Secrets and env files (*.env covers names like prod.env; .env.* covers .env.local, etc.)
*.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Packaging / local build outputs
*.egg-info/
.eggs/
dist/
build/

# Tests / coverage reports
.coverage
htmlcov/

# Experiment tracking (optional; harmless if unused)
wandb/
mlruns/

# Generated data under data/ (* matches fred_, yfinance_, or empty prefix)
# data/*pipeline_steps/
# data/*results/

# PCMCI/results: ignore all
# PCMCI/results/*

# granger_outputs/: ignore all
# granger_outputs/*

# lstm/: ignore all except top-level Python sources (plots, checkpoints, caches, etc.)
# lstm/*
# !lstm/*.py

# var/: ignore all except top-level Python sources (plots, checkpoints, caches, etc.)
# VAR/*
# !VAR/*.py
